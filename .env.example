SPRING_PROFILES_ACTIVE=local
# 格式：host:port（不要写 http:// 或 /nacos 后缀）
NACOS_SERVER_ADDR=
NACOS_NAMESPACE=
NACOS_GROUP=
NACOS_USERNAME=
NACOS_PASSWORD=
APP_PORT=8080

# SendGrid 联调（TC-EMAIL-D0-01，勿提交真实 Key）
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=collections@mocasa.com
# 模板 ID 写在 application-local.yml / Nacos channel.sendgrid.templates（scriptSlot → d-xxx）
# 可选：仅覆盖 S0 模板 ID
# SENDGRID_D0_TEMPLATE_ID=

# 通知中心 SMS/Push 生产签名（TC-SMS-PROD-*；testSend 免签名可不填）
# NOTIFICATION_APP_KEY=
