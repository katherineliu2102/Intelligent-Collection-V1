SPRING_PROFILES_ACTIVE=local
# 格式：host:port（不要写 http:// 或 /nacos 后缀）
NACOS_SERVER_ADDR=
NACOS_NAMESPACE=
NACOS_GROUP=
NACOS_USERNAME=
NACOS_PASSWORD=
APP_PORT=8080

# Email / SMS 密钥配置在 Nacos（勿写入 .env）：
#   intelligent-collection-local.yml → channel.sendgrid.api-key / from-email
#   intelligent-collection-local.yml → channel.notification.app-key
# 模板 ID：Nacos 或 application-local.yml → channel.sendgrid.templates（scriptSlot → d-xxx）
